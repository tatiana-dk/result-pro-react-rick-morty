{
    "name": "RM application",
    "short_name": "RM App",
    "description": "Rick and Morty application",
    "start_url": "/",
    "id": "/",
    "display": "standalone",
    "scope": "/",
    "background_color": "#ffffff",
    "theme_color": "#CCCCCC",
    "orientation": "portrait",
    "icons": [
        {
            "src": "/assets/icons/android-chrome-192x192.png",
            "sizes": "192x192",
            "type": "image/png",
            "purpose": "any maskable"
        },
        {
            "src": "/assets/icons/android-chrome-512x512.png",
            "sizes": "512x512",
            "type": "image/png"
        },
        {
            "src": "/assets/icons/apple-touch-icon-180x180.png",
            "sizes": "180x180",
            "type": "image/png"
        },
        {
            "src": "/assets/icons/apple-touch-icon-167x167.png",
            "sizes": "167x167",
            "type": "image/png"
        },
        {
            "src": "/assets/icons/apple-touch-icon-152x152.png",
            "sizes": "152x152",
            "type": "image/png"
        }
    ],
    "screenshots": [
        {
            "src": "/assets/screenshots/screenshot-desktop.png",
            "type": "image/png",
            "sizes": "1496x970",
            "form_factor": "wide"
        },
        {
            "src": "/assets/screenshots/screenshot-mobile.png",
            "type": "image/png",
            "sizes": "466x835",
            "form_factor": "narrow"
        }
    ],
    "protocol_handlers": [
        {
            "protocol": "web+character",
            "url": "/character?type=%s"
        },
        {
            "protocol": "web+location",
            "url": "/location?type=%s"
        },
        {
            "protocol": "web+episode",
            "url": "/episode?type=%s"
        }
    ],
    "display_override": ["window-controls-overlay"]
}